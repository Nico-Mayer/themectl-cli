{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Nico-Mayer/themectl-cli/main/schemas/settings.schema.json",
  "properties": {
    "integrations": {
      "items": {
        "type": "string",
        "enum": [
          "eza",
          "ghostty",
          "helix",
          "nvim",
          "system-appearance",
          "wallpaper",
          "yazi",
          "zed"
        ]
      },
      "type": "array",
      "uniqueItems": true,
      "description": "Integrations to run on theme apply. Replaces the default list."
    },
    "ghostty": {
      "properties": {
        "config_file": {
          "type": "string",
          "description": "Path to the file themectl edits. Supports env vars ($VAR) and a leading ~."
        }
      },
      "additionalProperties": false,
      "type": "object",
      "description": "Ghostty integration settings."
    },
    "helix": {
      "properties": {
        "config_file": {
          "type": "string",
          "description": "Path to the file themectl edits. Supports env vars ($VAR) and a leading ~."
        }
      },
      "additionalProperties": false,
      "type": "object",
      "description": "Helix integration settings."
    },
    "zed": {
      "properties": {
        "config_file": {
          "type": "string",
          "description": "Path to the file themectl edits. Supports env vars ($VAR) and a leading ~."
        }
      },
      "additionalProperties": false,
      "type": "object",
      "description": "Zed integration settings."
    },
    "nvim": {
      "properties": {
        "target": {
          "type": "string",
          "description": "Where the symlink is created. Supports env vars ($VAR) and a leading ~."
        }
      },
      "additionalProperties": false,
      "type": "object",
      "description": "Neovim integration settings."
    },
    "eza": {
      "properties": {
        "target": {
          "type": "string",
          "description": "Where the symlink is created. Supports env vars ($VAR) and a leading ~."
        }
      },
      "additionalProperties": false,
      "type": "object",
      "description": "Eza integration settings."
    },
    "yazi": {
      "properties": {
        "target": {
          "type": "string",
          "description": "Where the symlink is created. Supports env vars ($VAR) and a leading ~."
        }
      },
      "additionalProperties": false,
      "type": "object",
      "description": "Yazi integration settings."
    }
  },
  "additionalProperties": false,
  "type": "object",
  "title": "themectl.toml",
  "description": "themectl settings. Values set here override the built-in defaults."
}
